<?xml version="1.0" encoding="UTF-8"?>
<screen>

  <view style_bg_color="0x0C0C11" style_bg_opa="255" style_pad_all="0"
        scrollbar_mode="off" flag_scrollable="false">


    <!-- ═══ HEADER 480x36 ═══════════════════════════════════════════════ -->
    <lv_obj name="header"
            x="0" y="0" width="480" height="36"
            style_bg_color="0x131318" style_bg_opa="255"
            style_border_width="0" style_radius="0" style_pad_all="0"
            scrollbar_mode="off" flag_scrollable="false">

      <lv_obj name="accent_line"
              x="0" y="33" width="480" height="3"
              style_bg_color="0xE01A0A" style_bg_opa="255"
              style_border_width="0" style_radius="0"/>

      <lv_label name="lbl_title"
                x="10" y="9"
                text="&#x26A0; CERBERUS"
                style_text_color="0xE01A0A"
                style_text_font="lv_font_montserrat_16"/>

      <lv_label name="lbl_sim_badge"
                align="right_mid" align_ofs_x="-10" align_ofs_y="0"
                text="[ SIM ]"
                style_text_color="0xFFAA00"
                style_text_font="lv_font_montserrat_14"
                flag_hidden="true"/>

    </lv_obj>


    <!-- ═══ VERTICAL DIVIDER x=238 ══════════════════════════════════════ -->
    <lv_obj name="vdiv"
            x="238" y="38" width="2" height="186"
            style_bg_color="0x282835" style_bg_opa="255"
            style_border_width="0" style_radius="0"/>


    <!-- ═══ RPM PANEL left 238x186 ═══════════════════════════════════════ -->
    <lv_obj name="panel_rpm"
            x="0" y="38" width="238" height="186"
            style_bg_color="0x16161E" style_bg_opa="255"
            style_border_color="0x282835" style_border_width="1"
            style_radius="4" style_pad_all="0"
            scrollbar_mode="off" flag_scrollable="false">

      <lv_arc name="arc_rpm"
              width="180" height="180"
              align="center" align_ofs_x="-4" align_ofs_y="0"
              rotation="135"
              bg_start_angle="0" bg_end_angle="270"
              min_value="0" max_value="7000"
              value="0"
              flag_clickable="false"
              style_bg_opa="0"
              style_opa-knob="0"
              style_arc_color="0x232330"
              style_arc_width="13"
              style_arc_color-indicator="0xE01A0A"
              style_arc_width-indicator="13"/>

      <lv_label name="lbl_rpm_val"
                align="center" align_ofs_x="-4" align_ofs_y="-10"
                text="0"
                style_text_color="0xF0F0F2"
                style_text_font="lv_font_montserrat_32"/>

      <lv_label name="lbl_rpm_unit"
                align="center" align_ofs_x="-4" align_ofs_y="22"
                text="RPM"
                style_text_color="0x70707E"
                style_text_font="lv_font_montserrat_12"/>

    </lv_obj>


    <!-- ═══ GEAR PANEL right 238x186 ════════════════════════════════════ -->
    <lv_obj name="panel_gear"
            x="242" y="38" width="238" height="186"
            style_bg_color="0x16161E" style_bg_opa="255"
            style_border_color="0x282835" style_border_width="1"
            style_radius="4" style_pad_all="0"
            scrollbar_mode="off" flag_scrollable="false">

      <lv_label name="lbl_gear_title"
                align="top_mid" align_ofs_x="0" align_ofs_y="14"
                text="GEAR"
                style_text_color="0x70707E"
                style_text_font="lv_font_montserrat_16"/>

      <lv_label name="lbl_gear_val"
                align="center" align_ofs_x="0" align_ofs_y="10"
                text="N"
                style_text_color="0x28E028"
                style_text_font="lv_font_montserrat_48"/>

    </lv_obj>


    <!-- ═══ HORIZONTAL DIVIDER y=226 ════════════════════════════════════ -->
    <lv_obj name="hdiv"
            x="0" y="226" width="480" height="2"
            style_bg_color="0xE01A0A" style_bg_opa="255"
            style_border_width="0" style_radius="0"/>


    <!-- ═══ BOTTOM SENSOR STRIP 480x90 ══════════════════════════════════ -->
    <lv_obj name="strip_sensors"
            x="0" y="230" width="480" height="90"
            style_bg_color="0x0C0C11" style_bg_opa="255"
            style_border_width="0" style_radius="0" style_pad_all="0"
            scrollbar_mode="off" flag_scrollable="false">


      <!-- CLT — Coolant Temperature °C  x=0 -->
      <lv_obj name="panel_clt"
              x="0" y="0" width="96" height="90"
              style_bg_color="0x16161E" style_bg_opa="255"
              style_border_color="0x282835" style_border_width="1"
              style_radius="0" style_pad_all="0">

        <lv_label name="lbl_clt_title"
                  align="top_mid" align_ofs_x="0" align_ofs_y="8"
                  text="CLT"
                  style_text_color="0x70707E"
                  style_text_font="lv_font_montserrat_12"/>

        <lv_label name="lbl_clt_val"
                  align="center" align_ofs_x="0" align_ofs_y="4"
                  text="--"
                  style_text_color="0xF0F0F2"
                  style_text_font="lv_font_montserrat_24"/>

        <lv_label name="lbl_clt_unit"
                  align="bottom_mid" align_ofs_x="0" align_ofs_y="-6"
                  text="&#176;C"
                  style_text_color="0x70707E"
                  style_text_font="lv_font_montserrat_12"/>

      </lv_obj>


      <!-- OIL — Oil Pressure kPa  x=96 -->
      <lv_obj name="panel_oil"
              x="96" y="0" width="96" height="90"
              style_bg_color="0x16161E" style_bg_opa="255"
              style_border_color="0x282835" style_border_width="1"
              style_radius="0" style_pad_all="0">

        <lv_label name="lbl_oil_title"
                  align="top_mid" align_ofs_x="0" align_ofs_y="8"
                  text="OIL"
                  style_text_color="0x70707E"
                  style_text_font="lv_font_montserrat_12"/>

        <lv_label name="lbl_oil_val"
                  align="center" align_ofs_x="0" align_ofs_y="4"
                  text="--"
                  style_text_color="0xF0F0F2"
                  style_text_font="lv_font_montserrat_24"/>

        <lv_label name="lbl_oil_unit"
                  align="bottom_mid" align_ofs_x="0" align_ofs_y="-6"
                  text="kPa"
                  style_text_color="0x70707E"
                  style_text_font="lv_font_montserrat_12"/>

      </lv_obj>


      <!-- TPS — Throttle Position %  x=192 -->
      <lv_obj name="panel_tps"
              x="192" y="0" width="96" height="90"
              style_bg_color="0x16161E" style_bg_opa="255"
              style_border_color="0x282835" style_border_width="1"
              style_radius="0" style_pad_all="0">

        <lv_label name="lbl_tps_title"
                  align="top_mid" align_ofs_x="0" align_ofs_y="8"
                  text="TPS"
                  style_text_color="0x70707E"
                  style_text_font="lv_font_montserrat_12"/>

        <lv_label name="lbl_tps_val"
                  align="center" align_ofs_x="0" align_ofs_y="4"
                  text="--"
                  style_text_color="0xF0F0F2"
                  style_text_font="lv_font_montserrat_24"/>

        <lv_label name="lbl_tps_unit"
                  align="bottom_mid" align_ofs_x="0" align_ofs_y="-6"
                  text="%"
                  style_text_color="0x70707E"
                  style_text_font="lv_font_montserrat_12"/>

      </lv_obj>


      <!-- IAT — Intake Air Temp °C  x=288 -->
      <lv_obj name="panel_iat"
              x="288" y="0" width="96" height="90"
              style_bg_color="0x16161E" style_bg_opa="255"
              style_border_color="0x282835" style_border_width="1"
              style_radius="0" style_pad_all="0">

        <lv_label name="lbl_iat_title"
                  align="top_mid" align_ofs_x="0" align_ofs_y="8"
                  text="IAT"
                  style_text_color="0x70707E"
                  style_text_font="lv_font_montserrat_12"/>

        <lv_label name="lbl_iat_val"
                  align="center" align_ofs_x="0" align_ofs_y="4"
                  text="--"
                  style_text_color="0xF0F0F2"
                  style_text_font="lv_font_montserrat_24"/>

        <lv_label name="lbl_iat_unit"
                  align="bottom_mid" align_ofs_x="0" align_ofs_y="-6"
                  text="&#176;C"
                  style_text_color="0x70707E"
                  style_text_font="lv_font_montserrat_12"/>

      </lv_obj>


      <!-- MAP — Manifold Abs Pressure kPa  x=384 -->
      <lv_obj name="panel_map"
              x="384" y="0" width="96" height="90"
              style_bg_color="0x16161E" style_bg_opa="255"
              style_border_color="0x282835" style_border_width="1"
              style_radius="0" style_pad_all="0">

        <lv_label name="lbl_map_title"
                  align="top_mid" align_ofs_x="0" align_ofs_y="8"
                  text="MAP"
                  style_text_color="0x70707E"
                  style_text_font="lv_font_montserrat_12"/>

        <lv_label name="lbl_map_val"
                  align="center" align_ofs_x="0" align_ofs_y="4"
                  text="--"
                  style_text_color="0xF0F0F2"
                  style_text_font="lv_font_montserrat_24"/>

        <lv_label name="lbl_map_unit"
                  align="bottom_mid" align_ofs_x="0" align_ofs_y="-6"
                  text="kPa"
                  style_text_color="0x70707E"
                  style_text_font="lv_font_montserrat_12"/>

      </lv_obj>


    </lv_obj>

  </view>
</screen>
