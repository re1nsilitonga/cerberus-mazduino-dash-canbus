<?xml version="1.0" encoding="UTF-8"?>
<!--
  globals.xml — Cerberus Dashboard
  =================================
  Letakkan file ini di root project LVGL Pro (sejajar dengan screen XML).
  Daftarkan semua font yang dipakai di cerberus_dashboard.xml di sini.

  CATATAN src_path:
    - Jika pakai LVGL built-in Montserrat (dikompilasi ke firmware),
      set as_file="false" dan isi src_path dengan path ke file .ttf
      yang akan dikonversi oleh LVGL Pro Editor saat export.
    - Jika font sudah ada sebagai lv_font_t di firmware (LV_FONT_MONTSERRAT_XX=1
      di lv_conf.h), kamu bisa daftarkan via C dengan:
        lv_xml_register_font(NULL, "montserrat_12", &lv_font_montserrat_12);
      dan biarkan src_path kosong / hapus tag <fonts> ini.
-->
<globals>
  <fonts>

    <!-- 12px — sensor labels, unit labels, RPM unit -->
    <bin as_file="false"
         name="montserrat_12"
         src_path="fonts/Montserrat-Medium.ttf"
         size="12" bpp="4"
         range="0x20-0x7F"
         symbols="°%"/>

    <!-- 14px — SIM badge -->
    <bin as_file="false"
         name="montserrat_14"
         src_path="fonts/Montserrat-Medium.ttf"
         size="14" bpp="4"
         range="0x20-0x7F"/>

    <!-- 16px — header title, GEAR label -->
    <bin as_file="false"
         name="montserrat_16"
         src_path="fonts/Montserrat-Medium.ttf"
         size="16" bpp="4"
         range="0x20-0x7F"
         symbols="⚠"/>

    <!-- 24px — sensor values -->
    <bin as_file="false"
         name="montserrat_24"
         src_path="fonts/Montserrat-Medium.ttf"
         size="24" bpp="4"
         range="0x20-0x7F"
         symbols="-"/>

    <!-- 32px — RPM numeric value (digits only) -->
    <bin as_file="false"
         name="montserrat_32"
         src_path="fonts/Montserrat-Medium.ttf"
         size="32" bpp="4"
         range="0x30-0x39"/>

    <!-- 48px — Gear number (digits + N) -->
    <bin as_file="false"
         name="montserrat_48"
         src_path="fonts/Montserrat-Medium.ttf"
         size="48" bpp="4"
         range="0x30-0x39"
         symbols="N"/>

  </fonts>
</globals>